# Required by NextAuth, even for local-only use.
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# For OpenAI-compatible inference. For local vLLM, EMPTY is usually fine
# unless you started vLLM with an API key.
OPENAI_API_KEY="EMPTY"

# Example for local vLLM OpenAI-compatible server.
OPENAI_BASE_URL="http://localhost:8000/v1"

# Must match the model name served by your vLLM server.
OPENAI_MODEL=""
